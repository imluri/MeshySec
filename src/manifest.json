{
  "manifest_version": 3,
  "name": "Meshy GLB Exporter",
  "version": "0.1.0",
  "description": "Export your own Meshy models from the workspace viewer to GLB.",
  "permissions": [],
  "host_permissions": ["https://www.meshy.ai/*"],
  "content_scripts": [
    {
      "matches": ["https://www.meshy.ai/*"],
      "js": ["main.js"],
      "world": "MAIN",
      "run_at": "document_idle"
    },
    {
      "matches": ["https://www.meshy.ai/*"],
      "js": ["ui.js"],
      "css": ["button.css"],
      "run_at": "document_idle"
    }
  ]
}
